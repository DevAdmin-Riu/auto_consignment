FROM docker.n8n.io/n8nio/n8n

USER root

# xlsx-js-style, exceljs, axios 전역 설치
RUN npm install -g xlsx-js-style exceljs axios nodemailer

# n8n node_modules에 심볼릭 링크 (vm2 resolver가 찾을 수 있도록)
RUN ln -sf /usr/local/lib/node_modules/xlsx-js-style /usr/local/lib/node_modules/n8n/node_modules/xlsx-js-style 2>/dev/null; \
    ln -sf /usr/local/lib/node_modules/exceljs /usr/local/lib/node_modules/n8n/node_modules/exceljs 2>/dev/null; \
    ln -sf /usr/local/lib/node_modules/axios /usr/local/lib/node_modules/n8n/node_modules/axios 2>/dev/null; \
    ln -sf /usr/local/lib/node_modules/nodemailer /usr/local/lib/node_modules/n8n/node_modules/nodemailer 2>/dev/null; \
    true

USER node
