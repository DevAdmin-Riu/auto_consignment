{
  "name": "vendor-automation",
  "version": "1.0.0",
  "description": "Vendor order automation server",
  "main": "server-puppeteer.js",
  "scripts": {
    "start": "node server.js",
    "start:tracking": "node tracking-server.js",
    "pm2:start": "npx pm2 start ecosystem.config.cjs",
    "pm2:stop": "npx pm2 stop all",
    "pm2:restart": "npx pm2 restart all",
    "pm2:order": "npx pm2 restart order",
    "pm2:tracking": "npx pm2 restart tracking",
    "tracking:restart": "pkill -f 'node tracking-server' || true && node tracking-server.js",
    "tracking:stop": "pkill -f 'node tracking-server' || true",
    "pm2:logs": "npx pm2 logs",
    "pm2:status": "npx pm2 status",
    "win:stop": "taskkill /F /IM node.exe || exit 0",
    "mac:stop": "pkill -f 'node server' || true",
    "logs": "tail -f server.log",
    "docker:start": "docker compose -f ./docker-compose.yml up -d",
    "docker:stop": "docker compose -f ./docker-compose.yml down",
    "docker:restart": "docker compose -f ./docker-compose.yml restart",
    "docker:logs": "docker logs -f n8n",
    "docker:open": "open -a Docker"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "puppeteer-real-browser": "^1.4.4",
    "screenshot-desktop": "^1.15.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^6.0.1",
    "xlsx": "^0.18.5"
  }
}
